# Copy thành .env và điền giá trị thật
# KHÔNG commit file .env lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# App
APP_NAME=Day09 Multi-Agent API
APP_VERSION=1.0.0

# Day09 Agent — LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0
GOOGLE_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=4

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000
